# Discord Bot Token (required)
# Get yours from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Python TTS API URL (default: http://127.0.0.1:8000)
PYTHON_API_URL=http://127.0.0.1:8000

# Target guild (server) ID for auto-join (optional)
TARGET_GUILD_ID=

# Target voice channel ID to auto-join (optional)
TARGET_VOICE_CHANNEL_ID=

# Admin Web Panel (optional)
# Admin server listens on this port (default: 3000)
ADMIN_PORT=3000
# Set to "true" to disable the admin web server
ADMIN_DISABLED=false
# Optional API key for securing admin endpoints
ADMIN_API_KEY=

# Sentry Error Tracking (optional)
# Get your DSN from https://sentry.io/settings/projects/
# SENTRY_TRACES_SAMPLE_RATE controls performance tracing (0.0-1.0, defaults to 0.1)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
