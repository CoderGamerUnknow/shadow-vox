# ShadowVox Environment Configuration
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control!

# Discord bot token (required)
# Get yours at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord target server and voice channel (optional, for auto-join on startup)
TARGET_GUILD_ID=
TARGET_VOICE_CHANNEL_ID=

# Admin web panel port (default: 3000)
ADMIN_PORT=3000

# Set to "true" to disable the admin web panel
# ADMIN_DISABLED=false

# Admin API key for the web dashboard (optional, but recommended)
# Set this to a random string to protect your admin panel endpoints.
ADMIN_API_KEY=

# Python TTS server URL (default: http://127.0.0.1:8000)
PYTHON_API_URL=http://127.0.0.1:8000

# V3: INTERNAL_API_KEY — authenticates all requests between the Discord bot
# and the Python TTS engine. Set this to a long random string.
# If empty, requests proceed without auth (local dev mode).
# The bot sends this as X-API-KEY header on every request to /clone, /health, /voice-to-voice.
INTERNAL_API_KEY=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Sentry tracing sample rate (0.0 - 1.0, default: 0.1)
SENTRY_TRACES_SAMPLE_RATE=0.1
