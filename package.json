{
  "name": "shadow-vox",
  "version": "1.0.0",
  "description": "Real-time voice cloning Discord bot powered by Node.js, Discord.js audio streams, and a local Python XTTS-v2 neural engine.",
  "private": true,
  "type": "module",
  "scripts": {
    "install:bot": "bun install",
    "install:python": "cd python && pip install -r requirements.txt",
    "install": "bun run install:bot && bun run install:python",
    "dev:bot": "bun run src/index.ts",
    "dev:python": "cd python && python tts_server.py",
    "dev": "echo 'Run dev:bot and dev:python in separate terminals'",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@discordjs/opus": "^0.9.0",
    "@discordjs/voice": "^0.16.1",
    "axios": "^1.7.2",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "prism-media": "^1.3.5",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
